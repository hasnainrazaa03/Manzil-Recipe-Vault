# Base URL of the API server. Leave unset to default to http://localhost:4000
VITE_API_URL=http://localhost:4000

# Firebase web config. These are not secrets — they ship in the client bundle —
# but the Firebase Console's "Authorized domains" list must be kept restricted.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
