# ---- Core ----
# Port the API listens on (Render/Railway inject this automatically)
PORT=4000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/manzil-recipe-vault

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://manzil-recipe-vault.vercel.app

# ---- Firebase Admin ----
# Provide EITHER the full service-account JSON as a single-line string (preferred
# for hosted deploys), OR a path to the JSON file on disk (easier locally).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Folder that all user uploads are pinned to by the signed upload endpoint
CLOUDINARY_UPLOAD_FOLDER=manzil-recipe-vault
